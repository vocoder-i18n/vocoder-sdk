{
	"name": "@vocoder/extractor",
	"version": "0.1.0",
	"description": "Shared string extractor for Vocoder — Babel AST extraction of <T> components and t() calls",
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/vocoder/vocoder-sdk.git",
		"directory": "packages/extractor"
	},
	"keywords": [
		"i18n",
		"extraction",
		"ast",
		"babel"
	],
	"author": "Vocoder <admin@vocoder.app>",
	"license": "MIT",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@babel/core": "^7.26.0",
		"@babel/parser": "^7.26.0",
		"@babel/traverse": "^7.26.0",
		"@babel/types": "^7.26.0",
		"glob": "^10.3.10"
	},
	"devDependencies": {
		"@types/babel__core": "^7.20.5",
		"@types/babel__traverse": "^7.20.6",
		"@types/node": "^20.19.9",
		"tsup": "^8.0.0",
		"typescript": "^5.4.0"
	}
}
