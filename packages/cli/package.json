{
  "name": "@vocoder/cli",
  "version": "0.7.0",
  "description": "CLI tool for Vocoder translation workflow",
  "files": [
    "dist"
  ],
  "bin": {
    "vocoder": "dist/bin.mjs"
  },
  "exports": {
    "./lib": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vocoder/vocoder-sdk.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "translation",
    "cli",
    "localization",
    "extraction",
    "ast",
    "babel"
  ],
  "author": "Vocoder <admin@vocoder.app>",
  "license": "MIT",
  "homepage": "https://github.com/vocoder/vocoder-sdk#readme",
  "bugs": {
    "url": "https://github.com/vocoder/vocoder-sdk/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-dts --clean=false",
    "watch": "tsup --watch",
    "test": "vitest run --exclude 'src/__tests__/integration/**'",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude 'src/__tests__/integration/**'",
    "test:integration": "RUN_INTEGRATION=true vitest run src/__tests__/integration",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/core": "0.4.1",
    "@clack/prompts": "^0.9.1",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@vocoder/config": "workspace:*",
    "@vocoder/extractor": "workspace:*",
    "@types/node": "^20.19.9",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
