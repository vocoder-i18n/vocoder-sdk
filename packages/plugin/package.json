{
  "name": "@vocoder/plugin",
  "version": "0.12.0",
  "description": "Build plugin for Vocoder — injects translations as virtual modules at build time",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vocoder/vocoder-sdk.git",
    "directory": "packages/plugin"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "translation",
    "unplugin",
    "vite",
    "webpack",
    "rollup",
    "esbuild",
    "nextjs"
  ],
  "author": "Vocoder <admin@vocoder.app>",
  "license": "MIT",
  "homepage": "https://github.com/vocoder/vocoder-sdk#readme",
  "bugs": {
    "url": "https://github.com/vocoder/vocoder-sdk/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.mjs",
      "require": "./dist/webpack.js"
    },
    "./rollup": {
      "types": "./dist/rollup.d.ts",
      "import": "./dist/rollup.mjs",
      "require": "./dist/rollup.js"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.ts",
      "import": "./dist/esbuild.mjs",
      "require": "./dist/esbuild.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.mjs",
      "require": "./dist/next.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-dts --clean=false",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "unplugin": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "@vocoder/extractor": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  }
}
