{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"declaration": true,
		"esModuleInterop": true,
		"jsx": "react-jsx",
		"lib": ["ES2017", "ES2021.Intl", "DOM"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"outDir": "./dist",
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2017"
	},
	"include": ["src/**/*"],
	"exclude": [
		"node_modules",
		"dist",
		"**/__tests__/**",
		"**/*.test.tsx",
		"**/*.test.ts"
	]
}
