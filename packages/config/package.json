{
  "name": "@vocoder/config",
  "version": "0.13.2",
  "description": "Type helper for vocoder.config.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vocoder/vocoder-sdk.git",
    "directory": "packages/config"
  },
  "keywords": [
    "i18n",
    "internationalization",
    "translation",
    "vocoder"
  ],
  "author": "Vocoder <admin@vocoder.app>",
  "license": "MIT",
  "homepage": "https://github.com/vocoder/vocoder-sdk#readme",
  "bugs": {
    "url": "https://github.com/vocoder/vocoder-sdk/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-dts --clean=false",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "sideEffects": false
}
